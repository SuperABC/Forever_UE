{ //chapter1_meet_cpz
	"milestone": "chapter1_meet_cpz",
	"visible": false,
	"triggers": [{"type": "option_dialog", "name": "楚鹏展", "option": "你好"}],
	"dialogs": [
		{"condition": "$$plot_step==before_meet_cpz", "list": [
			{"speaker": "林逸", "content": "楚叔叔您好，我是林逸。"},
			{"speaker": "楚鹏展", "content": "你就是林逸？"},
			{"speaker": "林逸", "content": "是我。"},
			{"speaker": "李福", "content": "你好！我是楚董事长的秘书，李福，董事长正要我去火车站接您，没想到您已经到了！"},
			{"speaker": "林逸", "content": "没关系，就当熟悉熟悉路了。"},
			{"speaker": "楚鹏展", "content": "林先生，那我就开门见山了。我也知道，或许让你屈尊去做这些事情让你有些为难…"},
			{"speaker": "林逸", "content": "不屈尊，我在家里编草鞋一个月才赚几百块，老头子说这个任务够我吃一辈子了。"},
			{"speaker": "楚鹏展", "content": "什么？编草鞋？"},
			{"speaker": "林逸", "content": "是啊，一双草鞋能卖四块钱，一天编个三五双，一个月就是好几百了。"},
			{"speaker": "楚鹏展", "content": "以后你的工资是每个月三万块，这些钱包含你上学的学费和日常花销，当然，花在我女儿身上的钱，可以额外找李福报销。"},
			{"speaker": "林逸", "content": "三万？老头子不说几千块么？等等，楚先生，您刚才说什么？上学？学杂费？还有花在您女儿身上的钱？这是什么意思？我有点儿不明白…"},
			{"speaker": "楚鹏展", "content": "哦？怎么，林老爷子之前没和你说么？请这边来，具体情况，我们去楼上谈吧。"},
		]}
	],
	"changes": [
		{"type": "remove_option", "name": "楚鹏展", "value": "你好"},
		{"type": "add_option", "name": "楚鹏展", "option": "楚叔叔您说吧"},
